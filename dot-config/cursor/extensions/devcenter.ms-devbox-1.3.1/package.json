{
	"name": "ms-devbox",
	"displayName": "%extension.title%",
	"version": "1.3.1",
	"publisher": "DevCenter",
	"description": "%extension.description%",
	"aiKey": "0c6ae279ed8443289764825290e4f9e2-1a736e7c-1324-4338-be46-fc2a58ae4d14-7255",
	"icon": "images/DevBoxLogo.png",
	"author": {
		"name": "Microsoft"
	},
	"repository": {
		"type": "git",
		"url": "https://dev.azure.com/devdiv/OnlineServices/_git/azure-devcenter"
	},
	"engines": {
		"vscode": "^1.92.0"
	},
	"extensionDependencies": [
		"redhat.vscode-yaml"
	],
	"categories": [
		"AI",
		"Chat",
		"Linters",
		"Other"
	],
	"activationEvents": [
		"onCommand:devbox.runCommand",
		"onStartupFinished"
	],
	"main": "dist/extension.js",
	"contributes": {
		"yamlValidation": [
			{
				"fileMatch": "devbox.yaml",
				"url": "./schemas/1.0/devbox.yaml.schema.json"
			},
			{
				"fileMatch": "task.yaml",
				"url": "./schemas/1.0/task.yaml.schema.json"
			},
			{
				"fileMatch": "workload.yaml",
				"url": "./schemas/1.0/workload.yaml.schema.json"
			},
			{
				"fileMatch": "imagedefinition.yaml",
				"url": "./schemas/1.0/imagedefinition.yaml.schema.json"
			}
		],
		"chatParticipants": [
			{
				"id": "devbox-chat",
				"name": "devbox",
				"description": "%agent.chatHello%",
				"isSticky": false,
				"commands": [
					{
						"name": "customize",
						"description": "%agent.customize%"
					},
					{
						"name": "tasks",
						"description": "%agent.tasks%"
					}
				]
			}
		],
		"commands": [
			{
				"command": "devbox.listTasks",
				"category": "Dev Box",
				"title": "%commands.listtasks%"
			},
			{
				"command": "devbox.applyCustomizations",
				"category": "Dev Box",
				"title": "%commands.applytasks%"
			}
		],
		"keybindings": [
			{
				"command": "devbox.applyCustomizations",
				"key": "f5",
				"mac": "f5",
				"when": "editorFocus && editorLangId == yaml"
			},
			{
				"command": "devbox.listTasks",
				"key": "ctrl+alt+l",
				"mac": "cmd+alt+l",
				"when": "editorFocus"
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run package",
		"compile": "webpack",
		"watch": "webpack --watch --mode development",
		"package": "webpack --mode production --devtool hidden-source-map",
		"pretest": "npm run compile && npm run lint",
		"lint": "eslint src --ext ts",
		"test": "node ./out/test/runTest.js",
		"refreshAuth": "vsts-npm-auth -config .npmrc -F",
		"localize": "npm run ci-prepareLoc && npm run ci-deployLoc",
		"ci-localize": "gulp localizationBundle",
		"ci-prepareLoc": "gulp prepare",
		"ci-deployLoc": "copyfiles -u 2 .localization/out/**/* ./dist",
		"runExtension": "npm run compile && npm run ci-localize && npm run ci-deployLoc"
	},
	"devDependencies": {
		"@types/glob": "^8.1.0",
		"@types/js-yaml": "^4.0.9",
		"@types/mocha": "^10.0.1",
		"@types/node": "^20.5.9",
		"@types/vscode": "^1.90.0",
		"@typescript-eslint/eslint-plugin": "^5.59.8",
		"@typescript-eslint/parser": "^5.59.8",
		"@vscode/test-electron": "^2.3.2",
		"child_process": "^1.0.2",
		"copyfiles": "^2.4.1",
		"eslint": "^8.41.0",
		"glob": "^8.1.0",
		"gulp": "^4.0.2",
		"gulp-concat": "^2.6.1",
		"gulp-filter": "^7.0.0",
		"gulp-sourcemaps": "^3.0.0",
		"gulp-typescript": "^6.0.0-alpha.1",
		"mocha": "^10.2.0",
		"ts-loader": "^9.4.1",
		"typescript": "^5.1.3",
		"vscode-nls-dev": "^4.0.1",
		"webpack": "^5.89.0",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"@vscode/extension-telemetry": "^0.9.3",
		"@vscode/webview-ui-toolkit": "^1.2.2",
		"applicationinsights": "^2.9.5",
		"highlight.js": "^11.9.0",
		"js-yaml": "^4.1.0",
		"sanitize-filename": "^1.6.3",
		"semver": "^7.5.4",
		"vscode-nls": "^5.2.0"
	},
	"__metadata": {
		"id": "d672d99a-35b3-4150-b06e-571fc809e396",
		"publisherId": "e021113f-2fca-411a-bc53-773846c804d9",
		"publisherDisplayName": "DevCenter",
		"targetPlatform": "undefined",
		"isApplicationScoped": false,
		"isPreReleaseVersion": false,
		"hasPreReleaseVersion": false,
		"installedTimestamp": 1731567864239,
		"pinned": false,
		"preRelease": false,
		"source": "gallery"
	}
}