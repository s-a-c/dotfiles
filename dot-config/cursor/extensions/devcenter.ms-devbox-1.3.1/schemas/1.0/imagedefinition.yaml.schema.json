{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://aka.ms/devbox-imagedefinition-schema/1.0",
    "title": "imagedefinition.yaml schema",
    "description": "Schema for imagedefinition.yaml",
    "type": "object",
    "properties": {
        "$schema": {
            "$ref": "./workload.yaml.schema.json#/properties/$schema"
        },
        "name": {
            "$ref": "./workload.yaml.schema.json#/properties/name"
        },
        "description": {
            "type": "string",
            "description": "Description of the image definition"
        },
        "image": {
            "type": "string",
            "description": "Specifies the name of a base image to use for the dev box.",
            "examples": [
                "microsoftwindowsdesktop_windows-ent-cpc_win11-21h2-ent-cpc-m365",
                "my-gallery/my-image@0.0.1"
            ]
        },
        "tasks": {
            "$ref": "./workload.yaml.schema.json#/properties/tasks"
        },
        "userTasks": {
            "$ref": "./workload.yaml.schema.json#/properties/userTasks"
        }
    },
    "required": [
        "name",
        "image"
    ]
}