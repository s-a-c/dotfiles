{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://aka.ms/devbox-task-schema/1.0",
    "title": "task.yaml schema",
    "description": "Schema for task.yaml",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "description": "Version of the task.yaml file",
            "examples": [
                "1.0"
            ]
        },
        "name": {
            "type": "string",
            "description": "Id of the customization task"
        },
        "command": {
            "type": "string",
            "description": "Powershell command to run for the task"
        },
        "description": {
            "type": "string",
            "description": "Description of the customization task"
        },
        "author": {
            "type": "string",
            "description": "Information of the task author"
        },
        "issueNotificationEmail": {
            "type": "string",
            "description": "Email address that users should contact if they have any issues with the task. No product functionality leverages this setting."
        },
        "documentationURL": {
            "type": "string",
            "description": "URL of documentation of the task"
        },
        "licenseURL": {
            "type": "string",
            "description": "URL of license"
        },
        "keywords": {
            "type": "array",
            "description": "List of keywords relevant to a user that would search for this task.",
            "items": {
                "type": "string"
            }
        },
        "parameters": {
            "type": "object",
            "description": "List of inputs that can be passed to the task",
            "patternProperties": {
                "^.*$": {
                    "type": "object",
                    "description": "Name of the input parameter",
                    "properties": {
                        "type": {
                            "type": "string",
                            "description": "Data type of the input",
                            "enum": [
                                "string",
                                "boolean",
                                "number"
                            ]
                        },
                        "allowed": {
                            "type": "array",
                            "description": "A strict list of allowed string values of the input",
                            "items": {
                                "type": [
                                    "string"
                                ]
                            }
                        },
                        "default": {
                            "type": [
                                "string",
                                "boolean",
                                "number"
                            ],
                            "description": "Default value of the input"
                        },
                        "description": {
                            "type": "string",
                            "description": "Description of the input"
                        },
                        "validationRegex": {
                            "type": "string",
                            "description": "Validation regex for string input"
                        },
                        "minLength": {
                            "type": "integer",
                            "description": "Min length of string input"
                        },
                        "maxLength": {
                            "type": "integer",
                            "description": "Max length of string input"
                        },
                        "required": {
                            "type": "boolean",
                            "description": "Indicates if the input is required for the task",
                            "default": false
                        }
                    },
                    "required": [
                        "type"
                    ]
                }
            }
        },
        "timeout": {
            "type": "integer",
            "description": "Default timeout of executing a task. Unit is minute.",
            "default": 30
        },
        "documentation": {
            "type": "object",
            "description": "Documentation of the task to be used by the consumers of this task",
            "properties": {
                "notes": {
                    "type": "string",
                    "description": "Additional notes to be read by the consumers of this task"
                },
                "examples": {
                    "description": "A list of examples showing how to invoke this task from a devbox yaml file",
                    "$ref": "./workload.yaml.schema.json#/properties/tasks"
                }
            }
        },
        "rebootRequired": {
            "type": "boolean",
            "description": "Indicates if the task requires a reboot after execution",
            "default": false
        }
    },
    "required": [
        "$schema",
        "name",
        "command"
    ]
}