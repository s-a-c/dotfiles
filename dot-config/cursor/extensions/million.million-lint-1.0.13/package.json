{
	"name": "million-lint",
	"displayName": "Million Lint",
	"version": "1.0.13",
	"private": true,
	"description": "Identify, explain, and fix React performance issues",
	"license": "UNLICENSED",
	"author": "Million Software, Inc.",
	"publisher": "million",
	"main": "./dist/index.js",
	"scripts": {
		"build": "NODE_ENV=production tsup",
		"dev": "NODE_ENV=development tsup --watch",
		"pack": "vsce package --no-dependencies --allow-missing-repository",
		"publish": "vsce publish --no-dependencies --allow-missing-repository",
		"release": "bumpp && pnpm publish",
		"vscode:prepublish": "pnpm build",
		"vscode:uninstall": "node ./dist/uninstall.js"
	},
	"contributes": {
		"colors": [
			{
				"id": "millionlint.purple",
				"description": "Million Purple",
				"defaults": {
					"dark": "#c391d2",
					"light": "#9066DF",
					"highContrast": "#ffffff",
					"highContrastLight": "#000000"
				}
			},
			{
				"id": "millionlint.mutedpurple",
				"description": "Million Muted Purple",
				"defaults": {
					"dark": "#c391d21a",
					"light": "#9066df1a",
					"highContrast": "#ffffff1a",
					"highContrastLight": "#0000001a"
				}
			}
		],
		"commands": [
			{
				"command": "million.login",
				"title": "Million Lint: Login / Signup",
				"icon": "$(key)"
			},
			{
				"command": "million.logout",
				"title": "Million Lint: Logout",
				"icon": "$(key)"
			},
			{
				"command": "million.checkpoint",
				"title": "Million Lint: Create checkpoint",
				"icon": "$(clippy)"
			},
			{
				"command": "million.copyMachineId",
				"title": "Million Lint: Copy Machine ID",
				"icon": "$(clippy)"
			}
		],
		"configuration": {
			"title": "Million Lint",
			"properties": {
				"millionLint.baseUrl": {
					"type": "string",
					"default": "https://lint.million.dev",
					"description": "The base URL for the Million Lint API."
				}
			}
		},
		"views": {
			"million-lint": [
				{
					"type": "webview",
					"id": "million-webview",
					"name": "Dashboard",
					"icon": "media/million.svg",
					"contextualTitle": "Dashboard"
				}
			]
		},
		"viewsContainers": {
			"activitybar": [
				{
					"id": "million-lint",
					"title": "Million Lint",
					"icon": "media/million.svg"
				}
			]
		}
	},
	"activationEvents": [
		"onLanguage:javascript",
		"onLanguage:javascriptreact",
		"onLanguage:typescript",
		"onLanguage:typescriptreact",
		"onWebviewPanel:million-webview"
	],
	"dependencies": {
		"@axiomhq/js": "1.0.0-rc.3",
		"@babel/core": "7.25.2",
		"@babel/parser": "^7.26.2",
		"@babel/traverse": "^7.25.9",
		"@hono/node-server": "^1.11.1",
		"@million/rust": "workspace:*",
		"@vscode/vsce": "^3.2.1",
		"birpc": "^0.2.17",
		"diff": "^5.1.0",
		"hono": "^4.6.6",
		"nanoid": "^5.0.7",
		"ohash": "^1.1.4",
		"pathe": "^1.1.2",
		"perfect-debounce": "^1.0.0",
		"posthog-node": "^3.6.3",
		"pretty-ms": "8.0.0",
		"semver": "^7.6.2",
		"snappyjs": "^0.7.0",
		"socket.io": "^4.8.1",
		"undici": "^6.19.8",
		"zod": "^3.23.8",
		"zustand": "^4.5.2"
	},
	"devDependencies": {
		"@million/dashboard": "workspace:*",
		"@million/shared": "workspace:*",
		"@million/webview": "workspace:*",
		"@total-typescript/ts-reset": "^0.5.1",
		"@types/babel__traverse": "^7.20.6",
		"@types/diff": "^5.0.9",
		"@types/node": "^20.11.13",
		"@types/semver": "^7.5.8",
		"@types/snappyjs": "^0.7.1",
		"@types/vscode": "^1.84.1",
		"esbuild": "^0.20.1",
		"tsup": "^8.0.2",
		"typescript": "^5.4.5"
	},
	"engines": {
		"vscode": "^1.84.1"
	},
	"icon": "media/million.png",
	"__metadata": {
		"id": "c76878d7-9496-4200-bf09-b930e13c3f07",
		"publisherId": "35dba85f-3a4f-4f50-89ac-ae53a7bf56ba",
		"publisherDisplayName": "million",
		"targetPlatform": "undefined",
		"isApplicationScoped": false,
		"isPreReleaseVersion": false,
		"hasPreReleaseVersion": false,
		"installedTimestamp": 1732765527137,
		"pinned": false,
		"preRelease": false,
		"source": "gallery"
	}
}