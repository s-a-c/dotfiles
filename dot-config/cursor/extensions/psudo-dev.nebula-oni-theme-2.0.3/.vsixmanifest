<?xml version="1.0" encoding="utf-8"?>
	<PackageManifest Version="2.0.0" xmlns="http://schemas.microsoft.com/developer/vsx-schema/2011" xmlns:d="http://schemas.microsoft.com/developer/vsx-schema-design/2011">
		<Metadata>
			<Identity Language="en-US" Id="nebula-oni-theme" Version="2.0.3" Publisher="psudo-dev" />
			<DisplayName>Nebula Oni Theme</DisplayName>
			<Description xml:space="preserve">Oni (鬼) is a type of ogre youkai and &quot;Nebula Oni Theme&quot; has colors from Outer Space! Nebula Oni has a Menu with a lot of different options, give it a try, customize it!</Description>
			<Tags>nebula syntax,oni ui,semantic,italic,high contrast,atom,one dark,theme,color-theme</Tags>
			<Categories>Themes,Other</Categories>
			<GalleryFlags>Public</GalleryFlags>
			
			<Properties>
				<Property Id="Microsoft.VisualStudio.Code.Engine" Value="^1.61.0" />
				<Property Id="Microsoft.VisualStudio.Code.ExtensionDependencies" Value="" />
				<Property Id="Microsoft.VisualStudio.Code.ExtensionPack" Value="" />
				<Property Id="Microsoft.VisualStudio.Code.ExtensionKind" Value="ui,workspace" />
				<Property Id="Microsoft.VisualStudio.Code.LocalizedLanguages" Value="" />
				
				
				<Property Id="Microsoft.VisualStudio.Services.Links.Source" Value="https://github.com/psudo-dev/nebula-oni-theme.git" />
				<Property Id="Microsoft.VisualStudio.Services.Links.Getstarted" Value="https://github.com/psudo-dev/nebula-oni-theme.git" />
				<Property Id="Microsoft.VisualStudio.Services.Links.GitHub" Value="https://github.com/psudo-dev/nebula-oni-theme.git" />
				<Property Id="Microsoft.VisualStudio.Services.Links.Support" Value="https://github.com/psudo-dev/nebula-oni-theme/issues/new/choose" />
				<Property Id="Microsoft.VisualStudio.Services.Links.Learn" Value="https://github.com/psudo-dev/nebula-oni-theme/blob/main/README.md" />
				<Property Id="Microsoft.VisualStudio.Services.Branding.Color" Value="#F0F1F2" />
				<Property Id="Microsoft.VisualStudio.Services.Branding.Theme" Value="light" />
				<Property Id="Microsoft.VisualStudio.Services.GitHubFlavoredMarkdown" Value="true" />
				<Property Id="Microsoft.VisualStudio.Services.Content.Pricing" Value="Free"/>

				
				
			</Properties>
			<License>extension/LICENSE.md</License>
			<Icon>extension/icon.png</Icon>
