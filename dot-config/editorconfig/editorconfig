# Editor configuration, see https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

[*.ts]
quote_type = single
ij_typescript_use_double_quotes = false

[*.md]
trim_trailing_whitespace = true

[*.{yml,yaml}]
indent_size = 2

[docker-compose.yml]
indent_size = 2
