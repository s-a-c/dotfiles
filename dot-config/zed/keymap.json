  {
    "bindings": { // "context": "Pane"
      "cmd-k down": "pane::SplitDown",
      "cmd-k left": "pane::SplitLeft",
      "cmd-k right": "pane::SplitRight",
      "cmd-k up": "pane::SplitUp"
    },
    "context": "Pane"
  },
  // Bindings that should be unified with bindings for more general actions
  {
    "bindings": { // "context": "Editor && renaming"
      "enter": "editor::ConfirmRename"
    },
    "context": "Editor && renaming"
  },
  {
    "bindings": { // "context": "Editor && showing_completions"
      "enter": "editor::ConfirmCompletion",
      "tab": "editor::ComposeCompletion"
    },
    "context": "Editor && showing_completions"
  },
  {
    "bindings": { // "context": "Editor && inline_completion && !showing_completions"
      "tab": "editor::AcceptInlineCompletion"
    },
    "context": "Editor && inline_completion && !showing_completions"
  },
  {
    "bindings": { // "context": "Editor && showing_code_actions"
      "enter": "editor::ConfirmCodeAction"
    },
    "context": "Editor && showing_code_actions"
  },
  {
    "bindings": { // "context": "Editor && (showing_code_actions || showing_completions)"
      "ctrl-n": "editor::ContextMenuNext",
      "ctrl-p": "editor::ContextMenuPrev",
      "down": "editor::ContextMenuNext",
      "pagedown": "editor::ContextMenuLast",
      "pageup": "editor::ContextMenuFirst",
      "up": "editor::ContextMenuPrev"
    },
    "context": "Editor && (showing_code_actions || showing_completions)"
  },
  // Custom bindings
  {
    "bindings": { // "context": "Workspace"
      "cmd-alt-i": "zed::DebugElements",
      // TODO: Move this to a dock open action
      "cmd-shift-c": "collab_panel::ToggleFocus",
      "ctrl-:": "editor::ToggleInlayHints",
      "ctrl-alt-cmd-f": "workspace::FollowNextCollaborator"
    },
    "context": "Workspace"
  },
  {
    "bindings": { // "context": "Editor && mode == full"
      "alt-enter": "editor::OpenExcerpts",
      "cmd-f8": "editor::GoToHunk",
      "cmd-k enter": "editor::OpenExcerptsSplit",
      "cmd-shift-f8": "editor::GoToPrevHunk",
      "ctrl-enter": "assistant::InlineAssist",
      "shift-enter": "editor::ExpandExcerpts"
    },
    "context": "Editor && mode == full"
  },
  {
    "bindings": { // "context": "ProposedChangesEditor"
      "cmd-shift-a": "editor::ApplyAllDiffHunks",
      "cmd-shift-y": "editor::ApplyDiffHunk"
    },
    "context": "ProposedChangesEditor"
  },
  {
    "bindings": { // "context": "PromptEditor"
      "ctrl-[": "assistant::CyclePreviousInlineAssist",
      "ctrl-]": "assistant::CycleNextInlineAssist"
    },
    "context": "PromptEditor"
  },
  {
    "bindings": { // "context": "ProjectSearchBar && !in_replace"
      "cmd-enter": "project_search::SearchInNew"
    },
    "context": "ProjectSearchBar && !in_replace"
  },
  {
    "bindings": { // "context": "OutlinePanel && not_editing"
      "alt-cmd-r": "outline_panel::RevealInFileManager",
      "alt-cmd-shift-c": "outline_panel::CopyRelativePath",
      "alt-enter": "editor::OpenExcerpts",
      "cmd-alt-c": "outline_panel::CopyPath",
      "cmd-k enter": "editor::OpenExcerptsSplit",
      "escape": "menu::Cancel",
      "left": "outline_panel::CollapseSelectedEntry",
      "right": "outline_panel::ExpandSelectedEntry",
      "shift-down": "menu::SelectNext",
      "shift-up": "menu::SelectPrev",
      "space": "outline_panel::Open"
    },
    "context": "OutlinePanel && not_editing"
  },
  {
    "bindings": { // "context": "ProjectPanel"
      "alt-cmd-n": "project_panel::NewDirectory",
      "alt-cmd-r": "project_panel::RevealInFileManager",
      "alt-cmd-shift-c": "project_panel::CopyRelativePath",
      "backspace": [
        "project_panel::Trash",
        {
          "skip_prompt": false
        }
      ],
      "cmd-alt-backspace": [
        "project_panel::Delete",
        {
          "skip_prompt": false
        }
      ],
      "cmd-alt-c": "project_panel::CopyPath",
      "cmd-backspace": [
        "project_panel::Trash",
        {
          "skip_prompt": true
        }
      ],
      "cmd-c": "project_panel::Copy",
      "cmd-d": "project_panel::Duplicate",
      "cmd-delete": [
        "project_panel::Delete",
        {
          "skip_prompt": false
        }
      ],
      "cmd-n": "project_panel::NewFile",
      "cmd-shift-e": "project_panel::ToggleFocus",
      "cmd-shift-f": "project_panel::NewSearchInDirectory",
      "cmd-v": "project_panel::Paste",
      "cmd-x": "project_panel::Cut",
      "ctrl-shift-enter": "project_panel::OpenWithSystem",
      "delete": [
        "project_panel::Trash",
        {
          "skip_prompt": false
        }
      ],
      "enter": "project_panel::Rename",
      "escape": "menu::Cancel",
      "f2": "project_panel::Rename",
      "left": "project_panel::CollapseSelectedEntry",
      "right": "project_panel::ExpandSelectedEntry",
      "shift-down": "menu::SelectNext",
      "shift-up": "menu::SelectPrev"
    },
    "context": "ProjectPanel"
  },
  {
    "bindings": { // "context": "ProjectPanel && not_editing"
      "space": "project_panel::Open"
    },
    "context": "ProjectPanel && not_editing"
  },
  {
    "bindings": { // "context": "CollabPanel && not_editing"
      "ctrl-backspace": "collab_panel::Remove",
      "space": "menu::Confirm"
    },
    "context": "CollabPanel && not_editing"
  },
  {
    "bindings": { // "context": "(CollabPanel && editing) > Editor"
      "space": "collab_panel::InsertSpace"
    },
    "context": "(CollabPanel && editing) > Editor"
  },
  {
    "bindings": { // "context": "ChannelModal"
      "tab": "channel_modal::ToggleMode"
    },
    "context": "ChannelModal"
  },
  {
    "bindings": { // "context": "Picker > Editor"
      "alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": false
        }
      ],
      "cmd-alt-enter": [
        "picker::ConfirmInput",
        {
          "secondary": true
        }
      ],
      "tab": "picker::ConfirmCompletion"
    },
    "context": "Picker > Editor"
  },
  {
    "bindings": { // "context": "ChannelModal > Picker > Editor"
      "tab": "channel_modal::ToggleMode"
    },
    "context": "ChannelModal > Picker > Editor"
  },
  {
    "bindings": { // "context": "FileFinder"
      "cmd": "file_finder::ToggleMenu"
    },
    "context": "FileFinder"
  },
  {
    "bindings": { // "context": "FileFinder && !menu_open"
      "cmd-h": "pane::SplitLeft",
      "cmd-j": "pane::SplitDown",
      "cmd-k": "pane::SplitUp",
      "cmd-l": "pane::SplitRight",
      "cmd-shift-p": "file_finder::SelectPrev"
    },
    "context": "FileFinder && !menu_open"
  },
  {
    "bindings": { // "context": "FileFinder && menu_open"
      "h": "pane::SplitLeft",
      "j": "pane::SplitDown",
      "k": "pane::SplitUp",
      "l": "pane::SplitRight"
    },
    "context": "FileFinder && menu_open"
