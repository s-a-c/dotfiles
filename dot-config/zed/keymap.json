  {
    "bindings": { // "context": "Workspace && !Terminal"
      "alt-shift-t": "task::Spawn",
      "alt-t": "task::Spawn",
      "cmd-alt-r": "task::Rerun",
      "cmd-shift-r": "task::Spawn"
    },
    "context": "Workspace && !Terminal"
